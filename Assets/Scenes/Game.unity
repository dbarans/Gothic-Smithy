--- !u!114 &57047506
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 57047503}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f829a9a6a155a55438b678ac4b9940b3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Smithy.Dialogue.DialogueNPC
  npcDisplayName: Huno
  lines:
  - speaker: 0
    text: Chetnie sprobowalbym sil jako kowal.
    voiceClip: {fileID: 8300000, guid: 756e719b5d4a55b4daddb1829eca446f, type: 3}
  - speaker: 1
    text: Tylko nie wyobrazaj sobie, ze tak latwo jest wykuc solidny miecz!
    voiceClip: {fileID: 8300000, guid: 891392bf89f0a354f9eb82c1bdb0efb0, type: 3}
  - speaker: 0
    text: Co powinienem zrobic?
    voiceClip: {fileID: 8300000, guid: f9929c29f7f51d8478e3fad8c738d99a, type: 3}
  - speaker: 1
    text: Dobra, wez stal i rozgrzej ja nad ogniem.
    voiceClip: {fileID: 8300000, guid: b2592867a5272a245b4fbc72e084a03e, type: 3}
  - speaker: 1
    text: Potem rozbij ja na kowadle.
    voiceClip: {fileID: 8300000, guid: 25cf5cb41a9a3a144997fa916eb2044f, type: 3}
  - speaker: 1
    text: Jak skonczysz, wloz rozgrzane ostrze do wody, zeby je zahartowac.
    voiceClip: {fileID: 8300000, guid: 6fb9f3965906ec940b012ce39b23d1b6, type: 3}
  - speaker: 1
    text: Na koniec trzeba je jeszcze naostrzyc na kamieniu szlifierskim.
    voiceClip: {fileID: 8300000, guid: b6f0a33b5e213ee44b7d73a5ca834664, type: 3}
  - speaker: 0
    text: Rozumiem.
    voiceClip: {fileID: 8300000, guid: bc244e9c6628aca4bb39be8edb116095, type: 3}
  dialoguePanel: {fileID: 1463806599}
  audioSource: {fileID: 57047505}
  defaultDuration: 3
  pauseBetweenLines: 0.2
